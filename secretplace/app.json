{
  "expo": {
    "name": "secretplace",
    "slug": "secretplace",
    "scheme": "secretplace",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "app.secretplace.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationUsageDescription": "secretplace sends a quiet alert when your study session ends."
      }
    },
    "android": {
      "package": "app.secretplace.mobile",
      "permissions": [
        "ACCESS_NOTIFICATION_POLICY",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-notifications",
      "./plugins/withFocusMode.js"
    ]
  }
}
